{
    "$schema": "https://biomejs.dev/schemas/2.5.2/schema.json",
    "files": {
        "includes": ["**", "!dist", "!logs", "!coverage", "!node_modules"]
    },
    "formatter": {
        "enabled": true,
        "indentStyle": "space",
        "indentWidth": 4,
        "lineWidth": 120
    },
    "javascript": {
        "formatter": {
            "quoteStyle": "single",
            "semicolons": "always"
        }
    },
    "linter": {
        "enabled": true,
        "rules": {
            "preset": "recommended",
            "suspicious": {
                "noExplicitAny": "error",
                "noConsole": "warn"
            },
            "style": {
                "noNonNullAssertion": "warn",
                "noDefaultExport": "error"
            }
        }
    },
    "overrides": [
        {
            "includes": ["test/**"],
            "linter": {
                "rules": {
                    "suspicious": {
                        "noConsole": "off",
                        "noExplicitAny": "off"
                    },
                    "style": {
                        "noDefaultExport": "off"
                    }
                }
            }
        },
        {
            "includes": ["**/*.config.ts"],
            "linter": {
                "rules": {
                    "style": {
                        "noDefaultExport": "off"
                    }
                }
            }
        }
    ],
    "assist": {
        "actions": {
            "source": {
                "organizeImports": "on"
            }
        }
    }
}
