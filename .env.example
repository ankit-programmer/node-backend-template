# Server
PORT=3000
NODE_ENV=development
SERVICE_NAME=backend-template
LOG_LEVEL=info
LOG_TO_FILE=false

# Connections (each is required only by the module that uses it)
QUEUE_CONNECTION_URL=amqp://guest:guest@localhost:5672
REDIS_CONNECTION_STRING=redis://localhost:6379
MONGO_URI=mongodb://localhost:27017
RTLAYER_API_KEY=

# Auth
MASTER_API_KEY=
JWT_SECRET=

# Security toggles (defaults are permissive; flip to harden a deployment)
HELMET_ENABLED=false
RATE_LIMIT_ENABLED=false
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=300
CORS_ORIGINS=*
BODY_LIMIT=8mb

# Timeouts
HTTP_TIMEOUT_MS=30000
SHUTDOWN_TIMEOUT_MS=10000
RPC_TIMEOUT_SEC=30
